# Variables de entorno para el backend PHP (SICODI)
# Copia este archivo como .env o configura estas variables en Railway

# --- Base de Datos ---
DB_HOST=localhost
DB_NAME=sigdi
DB_USER=root
DB_PASS=

# --- URLs de la Aplicación ---
# URL pública del backend PHP en Railway (ej: https://sicodi-backend.up.railway.app)
APP_URL=https://tu-backend.up.railway.app

# URL pública del frontend Next.js en Railway (ej: https://sicodi-frontend.up.railway.app)
FRONTEND_URL=https://tu-frontend.up.railway.app
